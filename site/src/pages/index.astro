---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Approach from '../components/Approach.astro';
import ServiceCards from '../components/ServiceCards.astro';
import FitList from '../components/FitList.astro';
import Cases from '../components/Cases.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Timeline from '../components/Timeline.astro';
import TechStack from '../components/TechStack.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { ru } from '../data/content';

const content = ru;
---

<BaseLayout content={content}>
  <!-- Auto-detect language on first visit only -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('lang');
      if (stored === 'en') { window.location.replace('/en/'); return; }
      if (stored) return; // 'ru' stored — stay
      // No preference — check browser languages
      var langs = navigator.languages || [navigator.language || ''];
      var hasRu = langs.some(function(l) { return l.toLowerCase().indexOf('ru') === 0; });
      if (!hasRu) { window.location.replace('/en/'); }
    })();
  </script>
  <Nav nav={content.nav} />
  <Hero hero={content.hero} />
  <Approach approach={content.approach} />
  <ServiceCards services={content.services} />
  <FitList fit={content.fit} />
  <Cases cases={content.cases} lang={content.meta.lang} />
  <ProcessSteps process={content.process} />
  <CtaBanner ctaBanner={content.ctaBanner} />
  <Timeline experience={content.experience} />
  <TechStack stack={content.stack} />
  <FAQ faq={content.faq} />
  <Contact contact={content.contact} />
  <Footer footer={content.footer} />
</BaseLayout>
